{
  "expo": {
    "name": "MantraPuja Bhajan",
    "slug": "bhajan-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mantrapuja_logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/mantrapuja_logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F13"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/mantrapuja_logo.png",
        "backgroundColor": "#0F0F13"
      },
      "edgeToEdgeEnabled": true,
      "package": "mantra.puja.bhajan",
      "usesCleartextTraffic": true,
      "permissions": ["INTERNET"]
    },
    "web": {
      "favicon": "./assets/mantrapuja_logo.png"
    }
  }
}
